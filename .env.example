# Linq Partner API (iMessage / RCS / SMS)
LINQ_API_TOKEN=
LINQ_FROM_NUMBER=+1XXXXXXXXXX
LINQ_WEBHOOK_SECRET=
LINQ_PREFERRED_SERVICE=iMessage

# IBM watsonx
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_API_URL=https://us-south.ml.cloud.ibm.com

# BuckeyeLink (for browser automation)
OSU_USERNAME=
OSU_PASSWORD=

# Carmen Canvas (generate token at carmen.osu.edu/profile/settings)
CANVAS_API_URL=https://osu.instructure.com
CANVAS_API_TOKEN=

# Grubhub (for order authentication)
GRUBHUB_EMAIL=
GRUBHUB_PASSWORD=

# Supabase (memory + auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, never expose to clients
SUPABASE_API_KEY=your-api-key                      # safe for client-side / web dashboard

# OpenAI (fact embeddings — text-embedding-3-small)
OPENAI_API_KEY=
